# --- OpenAI --------------------------------------------------------------
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4o-mini

# --- Smart 1 Suite webhook ------------------------------------------------
# Where captured leads (plus their scan results) get POSTed as JSON.
# Get this URL from Smart 1 Suite's lead-intake / webhook settings.
SMART1_WEBHOOK_URL=https://your-smart1-suite-instance.example.com/webhooks/leads
# Optional bearer token if Smart 1 Suite's webhook requires auth.
SMART1_WEBHOOK_TOKEN=

# --- Misc ------------------------------------------------------------------
# Where the "Book My Strategy Call" button on the finished report sends people.
CALENDAR_URL=https://smart1marketing.com/book-a-call

# Render sets PORT automatically — no need to set this yourself on Render.
PORT=3000
